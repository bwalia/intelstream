# IntelStream Environment Variables
# Copy to .env and update values for your environment

# Broker
INTELSTREAM_BROKER_ID=1
INTELSTREAM_HOST=0.0.0.0
INTELSTREAM_PORT=9292
INTELSTREAM_DATA_DIR=./data

# Cluster
INTELSTREAM_CLUSTER_NAME=intelstream-default
INTELSTREAM_CLUSTER_PEERS=localhost:9292

# API
INTELSTREAM_REST_PORT=8080
INTELSTREAM_GRPC_PORT=9090

# Auth (disabled by default)
INTELSTREAM_AUTH_ENABLED=false
INTELSTREAM_JWT_SECRET=change-me-in-production
INTELSTREAM_AUTH_PROVIDER=jwt

# TLS (disabled by default)
INTELSTREAM_TLS_ENABLED=false
INTELSTREAM_TLS_CERT=
INTELSTREAM_TLS_KEY=
INTELSTREAM_TLS_CA=

# Schema Registry
INTELSTREAM_SCHEMA_REGISTRY_PORT=8081

# MCP
INTELSTREAM_MCP_ENABLED=true
INTELSTREAM_MCP_PORT=8090

# Logging
RUST_LOG=info
